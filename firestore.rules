rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 관리자 권한 확인 함수
    function isAdmin() {
      return request.auth != null && (
        (request.auth.token.email != null && 
         (request.auth.token.email == 'admin@pricehunter.com' || 
          request.auth.token.email == 'manager@pricehunter.com' || 
          request.auth.token.email == 'staff@pricehunter.com' || 
          request.auth.token.email == 'q886654@naver.com' ||
          request.auth.token.email == 'pricehunter.service@gmail.com')) ||
        request.auth.token.role == 'admin' ||
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    // users 컬렉션에 대한 규칙 (회원 데이터)
    match /users/{userId} {
      // 읽기: 모든 사용자 허용 (회원가입 시 중복 확인용)
      allow read: if true;
      // 쓰기: 회원가입과 로그인 시에만 허용
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }
    
    // admins 컬렉션 (관리자 계정)
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // inquiries 컬렉션에 대한 규칙 (문의 데이터)
    match /inquiries/{inquiryId} {
      // 읽기: 모든 사용자 허용
      allow read: if true;
      // 쓰기: 문의 작성만 허용
      allow create: if true;
      // 수정: 관리자만 허용 (답변 작성 및 댓글 관리)
      allow update: if isAdmin();
      allow delete: if false; // 문의 삭제는 허용하지 않음
    }
    
    // inquiryComments 컬렉션에 대한 규칙 (문의 댓글 데이터)
    match /inquiryComments/{commentId} {
      // 읽기: 모든 사용자 허용
      allow read: if true;
      // 쓰기: 모든 사용자가 댓글 작성 가능
      allow create: if true;
      // 수정: 관리자만 허용
      allow update: if isAdmin();
      // 삭제: 관리자만 허용
      allow delete: if isAdmin();
    }
    
    // reviews 컬렉션에 대한 규칙 (후기 데이터)
    match /reviews/{reviewId} {
      // 읽기: 모든 사용자 허용
      allow read: if true;
      // 쓰기: 후기 작성만 허용
      allow create: if true;
      // 수정: 관리자만 허용 (절약왕 수정 기능용)
      allow update: if isAdmin();
      // 삭제: 관리자만 허용
      allow delete: if isAdmin();
    }
    
    // requests 컬렉션에 대한 규칙 (요청 데이터)
    match /requests/{requestId} {
      // 읽기: 모든 사용자 허용
      allow read: if true;
      // 쓰기: 요청 작성만 허용
      allow create: if true;
      allow update: if isAdmin(); // 관리자는 의뢰 답변 작성 가능
      allow delete: if false; // 요청 삭제는 허용하지 않음
    }
    
    // orders 컬렉션에 대한 규칙 (주문 데이터)
    match /orders/{orderId} {
      // 읽기: 모든 사용자 허용
      allow read: if true;
      // 쓰기: 주문 생성만 허용
      allow create: if true;
      allow update: if false; // 주문 수정은 허용하지 않음
      allow delete: if false; // 주문 삭제는 허용하지 않음
    }
    
    // payments 컬렉션에 대한 규칙 (결제 데이터)
    match /payments/{paymentId} {
      // 읽기: 모든 사용자 허용
      allow read: if true;
      // 쓰기: 결제 정보 생성만 허용
      allow create: if true;
      allow update: if false; // 결제 정보 수정은 허용하지 않음
      allow delete: if false; // 결제 정보 삭제는 허용하지 않음
    }
    
    // 관리자 설정 컬렉션 (절약왕 관리 등)
    match /adminSettings/{settingId} {
      // 읽기: 관리자만
      allow read: if isAdmin();
      // 쓰기: 관리자만
      allow write: if isAdmin();
      // 삭제: 관리자만
      allow delete: if isAdmin();
    }
    
    // 방문 로그 (페이지별 상세)
    match /visits/{visitId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // 일별 방문 집계 (visit-tracker + 관리자 동기화)
    match /visitDaily/{dateId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // 월별 가입자 리포트 집계
    match /signupDaily/{monthId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // 월별 게스트(미가입) 의뢰자 집계
    match /guestRequestDaily/{monthId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // 월별 방문 집계 (리포트 조회 시 읽기 절약)
    match /visitMonthly/{monthId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // 다른 모든 컬렉션에 대한 기본 규칙
    match /{document=**} {
      // 읽기: 모든 사용자 허용
      allow read: if true;
      // 쓰기: 생성만 허용
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }
  }
} 