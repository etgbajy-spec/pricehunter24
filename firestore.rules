rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null &&
         (request.auth.token.email == 'admin@pricehunter.com' ||
          request.auth.token.email == 'manager@pricehunter.com' ||
          request.auth.token.email == 'staff@pricehunter.com' ||
          request.auth.token.email == 'q886654@naver.com' ||
          request.auth.token.email == 'pricehunter.service@gmail.com')) ||
        request.auth.token.role == 'admin' ||
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isOwnerUid(uid) {
      return isSignedIn() && uid != null && uid != '' && request.auth.uid == uid;
    }

    function emailMatches(email) {
      return isSignedIn() &&
        request.auth.token.email != null &&
        email != null &&
        request.auth.token.email == email;
    }

    function noPasswordField() {
      return !('password' in request.resource.data);
    }

    function ownsRequest() {
      return isAdmin() ||
        isOwnerUid(resource.data.userId) ||
        isOwnerUid(resource.data.uid) ||
        emailMatches(resource.data.email) ||
        emailMatches(resource.data.userEmail);
    }

    function ownsRequestCreate() {
      return isSignedIn() &&
        noPasswordField() &&
        (
          request.resource.data.userId == request.auth.uid ||
          request.resource.data.uid == request.auth.uid ||
          (
            request.auth.token.email != null &&
            request.resource.data.email is string &&
            request.resource.data.email == request.auth.token.email
          )
        );
    }

    match /users/{userId} {
      allow get: if isAdmin() || isOwnerUid(userId);
      allow list: if isAdmin();
      allow create: if isSignedIn() &&
        request.auth.uid == userId &&
        noPasswordField();
      allow update: if (isAdmin() || isOwnerUid(userId)) &&
        noPasswordField() &&
        (!('password' in resource.data) || !('password' in request.resource.data));
      allow delete: if isAdmin();
    }

    match /phoneIndex/{phoneId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /inquiries/{inquiryId} {
      allow get: if isAdmin() ||
        emailMatches(resource.data.email) ||
        isOwnerUid(resource.data.userId);
      allow list: if isAdmin() ||
        (isSignedIn() &&
         request.auth.token.email != null &&
         resource.data.email == request.auth.token.email);
      allow create: if true;
      allow update: if isAdmin() ||
        (isSignedIn() && emailMatches(resource.data.email));
      allow delete: if isAdmin();
    }

    match /inquiryComments/{commentId} {
      allow read: if isAdmin() || isSignedIn();
      allow create: if isSignedIn() || true;
      allow update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() || true;
      allow update, delete: if isAdmin();
    }

    match /requests/{requestId} {
      allow get: if ownsRequest();
      allow list: if isAdmin() ||
        (isSignedIn() &&
         request.auth.token.email != null &&
         resource.data.email == request.auth.token.email);
      allow create: if ownsRequestCreate();
      allow update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if isAdmin() ||
        isOwnerUid(resource.data.userId) ||
        emailMatches(resource.data.email);
      allow list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow get: if isAdmin() ||
        isOwnerUid(resource.data.userId) ||
        emailMatches(resource.data.email);
      allow list: if isAdmin();
      allow create: if false;
      allow update, delete: if isAdmin();
    }

    match /pointsLedger/{ledgerId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /adminSettings/{settingId} {
      allow read, write, delete: if isAdmin();
    }

    match /visits/{visitId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if false;
    }

    // 방문 집계: PII 없음. 클라이언트 visit-tracker 유지용으로 생성/갱신 허용
    match /visitDaily/{dateId} {
      allow read: if isAdmin();
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    match /visitMonthly/{monthId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /signupDaily/{monthId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /guestRequestDaily/{monthId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
