{
  "name": "pricehunter",
  "version": "1.0.0",
  "description": "PriceHunter - 가격 비교 및 구매 대행 서비스",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:1000": "node start-1000.js",
    "dev": "nodemon server.js",
    "build": "npx tailwindcss -c tailwind.config.js -i ./styles/tailwind-input.css -o ./styles/tailwind.build.css --minify",
    "build:css": "npm run build"
  },
  "keywords": [
    "pricehunter",
    "firebase",
    "price-comparison",
    "shopping"
  ],
  "author": "PriceHunter Team",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/firestore": "^8.3.0",
    "csrf": "^3.1.0",
    "dompurify": "^3.3.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.18.2",
    "firebase-admin": "^11.11.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "firebase-tools": "^13.35.1",
    "nodemon": "^3.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
