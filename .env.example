# PriceHunter — 알림·인증 환경변수 예시
# 복사: cp .env.example .env 후 값 입력

# 사이트 URL (이메일·알림톡 링크)
SITE_URL=https://pricehunt24.com

# EmailJS 서버 발송 (브라우저 제한 우회 — EmailJS 대시보드에서 Private Key 발급)
EMAILJS_PRIVATE_KEY=

# Firebase Admin (Netlify Functions / server.js)
FIREBASE_PROJECT_ID=pricehunter-99a1b
FIREBASE_ADMIN_PRIVATE_KEY=
FIREBASE_ADMIN_CLIENT_EMAIL=

# Solapi 카카오 알림톡 (미설정 시 이메일만 발송)
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=
SOLAPI_PFID=
SOLAPI_TEMPLATE_REQUEST_RECEIVED=
SOLAPI_TEMPLATE_REQUEST_COMPLETE=

# 게스트 체험 1회 제한 (true/false)
GUEST_TRIAL_STRICT_LIMITS=false
