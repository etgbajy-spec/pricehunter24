# PriceHunter 환경변수 설정

# 서버 설정
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# 본인인증 서비스 (KG이니시스)
KG_MERCHANT_ID=여기에_상점ID_입력
KG_API_KEY=여기에_API키_입력

# JWT 설정
JWT_SECRET=여기에_JWT_시크릿키_입력
SESSION_SECRET=여기에_세션_시크릿키_입력

# 토스페이먼츠 (서버 승인/취소)
# TOSS_SECRET_KEY=test_sk_...

# 관리자 대시보드: 구매확정 시 배송완료 단계 검증 생략(로컬 테스트만 권장)
# ADMIN_RELAX_FULFILLMENT=1

# 데이터베이스 (선택사항 - 향후 확장용)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=pricehunter
# DB_USER=username
# DB_PASSWORD=password

# AI 분석 파이프라인 (Phase 2)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# ADMIN_API_SECRET=운영환경_강력한_비밀키
# (로컬 개발 기본값: pricehunter-dev-admin — server.js NODE_ENV!=production)