# PriceHunter 환경변수 설정

# 서버 설정
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000
SITE_URL=https://pricehunt24.com

# JWT / 세션
JWT_SECRET=여기에_JWT_시크릿키_입력
SESSION_SECRET=여기에_세션_시크릿키_입력

# Firebase Admin (Netlify Functions / server.js)
# FIREBASE_PROJECT_ID=pricehunter-99a1b
# FIREBASE_ADMIN_CLIENT_EMAIL=...
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# PortOne (아임포트) 결제 검증/취소
# PORTONE_IMP_KEY=
# PORTONE_IMP_SECRET=

# 토스페이먼츠 (레거시 취소 경로용, 선택)
# TOSS_SECRET_KEY=test_sk_...

# 관리자 대시보드: 구매확정 시 배송완료 단계 검증 생략(로컬 테스트만 권장)
# ADMIN_RELAX_FULFILLMENT=1
# ADMIN_API_SECRET=운영환경_강력한_비밀키

# 게스트 체험 1회 제한 (운영에서는 true 권장)
GUEST_TRIAL_STRICT_LIMITS=true

# ----- 카카오 알림톡 (Solapi) -----
# Netlify 환경변수와 동일하게 설정하면 /api/notification-config 에서 configured:true 로 표시됩니다.
# SOLAPI_API_KEY=
# SOLAPI_API_SECRET=
# SOLAPI_SENDER=01000000000
# SOLAPI_PFID=카카오_발신프로필_ID
# SOLAPI_TEMPLATE_REQUEST_RECEIVED=의뢰접수_템플릿ID
# SOLAPI_TEMPLATE_REQUEST_COMPLETE=리포트완료_템플릿ID

# EmailJS / 고객·관리자 메일 (기존 customer-notify-email / admin-notify-email 참고)
# EMAILJS_SERVICE_ID=
# EMAILJS_TEMPLATE_ID=
# EMAILJS_PUBLIC_KEY=
# EMAILJS_PRIVATE_KEY=

# AI 분석 파이프라인 (선택)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
